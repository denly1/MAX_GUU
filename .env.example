# Bot secrets / runtime settings
MAX_BOT_TOKEN=

# Список MAX user_id первых администраторов через запятую.
# Эти пользователи получают роль администратора автоматически при /start.
# Узнать свой user_id можно командой /id в боте.
ADMIN_IDS=

# Путь к файлу базы данных SQLite (по умолчанию data/bot.db)
DB_PATH=data/bot.db

# Static bot content. Copy to .env on the server and edit there.
BOT_NAME='"Бот | Обучение служением"'
WELCOME_TEXT='"Привет!\n\nМы рады приветствовать тебя в боте программы «Обучение служением»!\n\nЗдесь ты сможешь выбирать задачи от социальных партнеров, получить ответы на все вопросы по программе и запланировать встречи по проекту.\n\nМы очень надеемся, что с помощью бота вам будет намного удобнее организовывать свою работу в команде и желаем успешной реализации проектов!"'
REGISTRATION_DONE='"Благодарим за регистрацию! Теперь вам доступен весь функционал бота."'
REGISTRATION_DONE_ADMIN='"Благодарим за регистрацию! Теперь вам доступен весь функционал бота."'
NEED_REGISTRATION='"Эта функция доступна только после регистрации. Пройдите регистрацию, нажав кнопку «Регистрация»."'

# FAQ_ITEMS — список пар ["вопрос", "ответ"]
FAQ_ITEMS='[]'

# ADMIN_CONTACTS — список контактов ["ФИО", "телефон", "telegram", "URL фото"]
ADMIN_CONTACTS='[]'

# Справочники для регистрации
INSTITUTES='[]'
DEPARTMENTS='[]'
COURSES='["1","2","3","4"]'
STUDY_PROGRAMS='[]'

# Шаблоны отчётности
TEMPLATE_PRESENTATION='""'
TEMPLATE_VISITKA='""'

# Источники заявки на проект
APPLICATION_SOURCES='[]'

ROLE_LABELS='{"student":"Студент","teacher":"Преподаватель","partner":"Социальный заказчик","admin":"Администратор"}'
DEFAULT_MEME='[]'
